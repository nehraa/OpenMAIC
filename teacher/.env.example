# PostgreSQL Database Connection
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/aidutech_teacher

# JWT Secret for token signing (use a long random string in production)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Classroom access code shared with teachers for the OpenMAIC Core UI.
# Must match the value Core enforces on /classroom.
# ACCESS_CODE=your-secret-code
